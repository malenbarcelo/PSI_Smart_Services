<%- include('../partials/head') %>

<div class="divCertificate">
    <div class="header">
        <div class="divHeaderLogo"><img src="/images/certificateImages/<%= certificateTemplate.logo1 %>" alt="Logo1" class="headerLogo1"></div>
        <div class="divHeaderLogo"><img src="/images/certificateImages/<%= certificateTemplate.logo2 %>" alt="Logo1" class="headerLogo2"></div>
        <div class="headerData">
            <div>Certificado de aprobación curso teórico-práctico</div>
            <div>ARGENTINA, Neuquén <%= issueDateString %></div>
            <div>Código: <%= certificateCode %></div>
        </div>
    </div>

    <div class="certificateText">
        <div class="studentName"><%= certificateData.last_name.toUpperCase() + ' ' + certificateData.first_name.toUpperCase() %></div>
        <div class="studentDni">DNI: <%= certificateData.dni %></div>
        <div class="text1"><%= certificateTemplate.text1 %></div>
        <div class="validity">Vigente hasta el <%= expirationDateString %></div>
        <div class="text2"><%= certificateTemplate.text2 %></div>
        <div class="text3">El día <%= certificateData.date.getDate() + ' de ' + issueMonth + ', ' + certificateTemplate.text3 %></div>
    </div>

    <div class="signatures">
        <div class="signature"><img src="/images/certificateImages/<%= certificateTemplate.signature1_image %>" alt="Firma1" class="imgSignature"></div>
        <div class="signature"><img src="/images/certificateImages/<%= certificateTemplate.signature2_image %>" alt="Firma2" class="imgSignature"></div>

    </div>
</div>



